# --- Round 2+: Embeddings via OpenAI ---
# We'll use text-embedding-3-small. Roughly $0.008 to embed a whole book.
# OPENAI_API_KEY=sk-...

# --- Round 4+: Generation via Anthropic (Claude Sonnet) ---
# Primary LLM for the Socratic response loop.
# ANTHROPIC_API_KEY=sk-ant-...
